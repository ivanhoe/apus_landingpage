{
  "compilerOptions": {
    "allowJs": true,
    "baseUrl": ".",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "skipLibCheck": true,
    "target": "ES2020",
    "paths": {
      "*": [ "./deps/*", "node_modules/*" ]
    },
    "strict": true,
    "types": [ "vite/client", "node" ]
  },
  "include": [
    "./assets/js/**/*",
    "./assets/vue/**/*"
  ],
  "exclude": [
    "node_modules"
  ]
}
